# flyctl launch added from .gitignore
# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
.pnp
**/.pnp.*
**/.yarn/*
!**/.yarn/patches
!**/.yarn/plugins
!**/.yarn/releases
!**/.yarn/versions

# testing
coverage

# next.js
.next
out

# production
build

# misc
**/.DS_Store
**/*.pem

# debug
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*

# env files (can opt-in for committing if needed)
**/.env*.local
**/.env.local
**/.env.production
# do NOT ignore .env.example — it's safe to commit

# vercel
**/.vercel

# typescript
**/*.tsbuildinfo
**/next-env.d.ts

# flyctl launch added from node_modules/.pnpm/loglevel@1.9.1/node_modules/loglevel/vendor/grunt-template-jasmine-requirejs/tasks/.gitignore
# Ignore everything in this directory
node_modules/.pnpm/loglevel@1.9.1/node_modules/loglevel/vendor/grunt-template-jasmine-requirejs/tasks/**/*
# Except this file
!node_modules/.pnpm/loglevel@1.9.1/node_modules/loglevel/vendor/grunt-template-jasmine-requirejs/tasks/**/.gitignore
fly.toml
